# =============================================================================
# Project4 AA Stack - Production Environment Configuration
# =============================================================================
# Copy this file and fill all values for production deployment.
# NEVER commit .env.prod to version control.
# Usage: docker compose -f infra/docker/docker-compose.prod.yml --env-file .env.prod up -d
# =============================================================================

# -----------------------------------------------------------------------------
# PRODUCTION BLOCKCHAIN RPC - Replace with your production RPC provider
# -----------------------------------------------------------------------------
# Production RPC URL - Use a reliable provider like Alchemy, Infura, QuickNode, etc.
# For Polygon mainnet: https://polygon-mainnet.infura.io/v3/YOUR_PROJECT_ID
# For Polygon Amoy testnet: https://polygon-amoy.infura.io/v3/YOUR_PROJECT_ID
PRODUCTION_RPC_URL=https://rpc.ankr.com/polygon/8ffa854920faddd72150c936d7563e370d556d26045476cb1366c69453035378

# -----------------------------------------------------------------------------
# CONTRACT DEPLOYER - Production Deployment Service
# -----------------------------------------------------------------------------
# Set to true when deploying to production (skips Anvil-specific RPC calls)
CONTRACT_DEPLOYER_PRODUCTION=true
# If true, contract-deployer skips mock account deployments, only runs Project4Paymaster
CONTRACT_DEPLOYER_SKIP_DEPLOYMENTS=true
# If true, deploy Project4Paymaster during contract-deployer run
CONTRACT_DEPLOYER_DEPLOY_PROJECT4_PAYMASTER=true
# Path where deployed paymaster address is written (Docker: /deploy-output/paymaster-address)
CONTRACT_DEPLOYER_PAYMASTER_ADDRESS_FILE=/deploy-output/paymaster-address
# USDC contract address on the target network
PAYMASTER_CONTRACT_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
# Paymaster signer address (EOA that will sign paymaster operations) private key: 0x52ecef1048853cd494949c87e702567f36c8f3c43673928150812a644ed2dbbb
PAYMASTER_CONTRACT_SIGNER_ADDRESS=0xdc1CD99115ACA74f8e4aF7cE05DCBA56d54216B6
# Treasury address for collecting fees private key: 0x2be024d79c69a2357392cb56ec2fa4b2dc3bd518d0d4466ead2a152635911ea9
PAYMASTER_CONTRACT_TREASURY_ADDRESS=0x71e3866E404C4C3A4246F213EF48B4e03117EB0b
# Override path to contracts/artifacts (default: auto-resolved relative to contract-deployer)
CONTRACT_DEPLOYER_CONTRACTS_ARTIFACTS_PATH=/app/contracts-artifacts
# Private key for Hardhat deploy scripts - SECURE THIS IN PRODUCTION! address: 0x97cfdCA01CfdCd31F471C9EdF83199dfD304cC2A
CONTRACT_DEPLOYER_PRIVATE_KEY=0xdc0f1f5e6ace3b01a77c5da0b44ae8241095bbbad65a922ded318742bf5130a0

# -----------------------------------------------------------------------------
# BUNDLER ALTO - Production Configuration
# -----------------------------------------------------------------------------
# Entrypoint contract address for the target network
PAYMASTER_CONTRACT_ENTRYPOINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
# Network name for Alto (should match your target network)
ALTO_NETWORK_NAME=polygon
# Log level for production
ALTO_LOG_LEVEL=info
# Minimum balance for bundler operations (in wei)
ALTO_MIN_BALANCE=1000000000000000000
# Maximum block range for user operations
ALTO_BLOCK_RANGE_LIMIT=10000
# Utility private key for bundler operations - SECURE THIS!
ALTO_UTILITY_PRIVATE_KEY=0x3d415b67c88daa5b2fbc8efe349b6cb67063cf59527c364804ade9993e686728
# Executor private keys (comma-separated) - SECURE THESE!
ALTO_EXECUTOR_PRIVATE_KEYS=0x46a3f5d23fe879153ad42f93a09990177a88b6b9c1cd04ed240ebb70335b71c7,0xce170d559c07d0a23bfbfbbabcea40789e4dd470e36910e9079ae403ebf267ee,0x25134a2f97a2050f58e013c8a63cd812146e59a40c4261c624ce6817d5b0d5db

# -----------------------------------------------------------------------------
# PAYMASTER API - Production Configuration
# -----------------------------------------------------------------------------
# Bundler URL (internal Docker network)
PAYMASTER_API_BUNDLER_URL=http://bundler-alto:4337
# Valkey/Redis connection URL
VALKEY_URL=redis://valkey:6379
# Key prefix for Redis operations
VALKEY_KEY_PREFIX=project4
# Paymaster signer private key - SECURE THIS!
PAYMASTER_CONTRACT_SIGNER_PRIVATE_KEY=0x52ecef1048853cd494949c87e702567f36c8f3c43673928150812a644ed2dbbb
# Gas limits for paymaster operations
PAYMASTER_CONTRACT_VERIFICATION_GAS_LIMIT=150000
PAYMASTER_CONTRACT_POSTOP_GAS_LIMIT=50000
# Quote buffer in basis points (e.g., 100 = 1%)
PAYMASTER_API_QUOTE_BUFFER_BPS=100
# Quote validity in seconds
PAYMASTER_API_VALIDITY_SECONDS=300
# Stub maximum cost in USDC (micro units)
PAYMASTER_API_STUB_MAX_COST_USDC_E6=1000000
# Minimum post-operation fee in USDC (micro units)
PAYMASTER_API_MIN_POSTOP_FEE_USDC_E6=1000
# API port
PAYMASTER_API_PORT=3000
# Entrypoint address (should match bundler config)
PAYMASTER_API_ENTRYPOINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
# Service fee in basis points
PAYMASTER_API_SERVICE_FEE_BPS=50

# -----------------------------------------------------------------------------
# DASHBOARD - Production Configuration
# -----------------------------------------------------------------------------
# Redis URL (alias for Valkey)
REDIS_URL=redis://valkey:6379
# Treasury address for dashboard display
DASHBOARD_TREASURY_ADDRESS=0x71e3866E404C4C3A4246F213EF48B4e03117EB0b
# USDC contract address for the network
DASHBOARD_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
# Paymaster API URL (internal Docker network)
PAYMASTER_API_URL=http://paymaster-api:3000
# Bundler URL for dashboard
DASHBOARD_BUNDLER_URL=http://bundler-alto:4337
# Entrypoint address for dashboard
DASHBOARD_ENTRYPOINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
# Utility private key for dashboard operations - SECURE THIS!
DASHBOARD_ALTO_UTILITY_KEY=0x7bcda70e9cf62d533d27a39b1a2d5c8c981305527080e3533045ca3668ffc69b
# Executor keys for dashboard (comma-separated) - SECURE THESE!
DASHBOARD_ALTO_EXECUTOR_KEYS=0xa381c7332164fb00ea281ec18efbaff31971f8c1c99a4b40ba7bcf3319713b40,0xf869c90dae46bf2ba557376d0c9a3eb4b63576224364fd75212bbfce8b08559a,0x591b21211f501cb37e187008ef33fa0db7107e586960d6a392e18f6ea1babb19
# Redis key prefix
REDIS_KEY_PREFIX=project4
# Polling interval in milliseconds
POLL_INTERVAL_MS=10000
# Worker swap amount in USDC micro units
WORKER_SWAP_USDC_E6=1000000
# Minimum entrypoint deposit in wei
MIN_ENTRYPOINT_DEPOSIT_WEI=1000000000000000000
# Cap entrypoint balance in wei
CAP_ENTRYPOINT_BALANCE_WEI=10000000000000000000
# Minimum worker deposit in wei
MIN_WORKER_DEPOSIT_WEI=100000000000000000
# Cap worker balance in wei
CAP_WORKER_BALANCE_WEI=1000000000000000000

# -----------------------------------------------------------------------------
# WORKER - Production Configuration
# -----------------------------------------------------------------------------
# Worker bootstrap private key - SECURE THIS!
WORKER_BOOTSTRAP_PRIVATE_KEY=0xa9d1b304635a9cfc298323510e9e49e028b96adc712aa1f23a5f43e9fd36ce02
# Worker revenue private key - SECURE THIS!
WORKER_REVENUE_PRIVATE_KEY=0xfd10cad175d51b12699a9d4a5af85231e06be473d1fcb9a433f1dae00d1c2846
# Revenue collection address
WORKER_REVENUE_ADDRESS=0x8637138D3f8F015B06Cb0A81Ec19BCF4b8007519
# Monitoring interval in seconds
WORKER_MONITORING_INTERVAL_SECONDS=60
# Minimum bootstrap USDC balance
WORKER_MIN_BOOTSTRAP_USDC=10
# Minimum bootstrap gas balance
WORKER_MIN_BOOTSTRAP_GAS=0.1
# Minimum worker USDC balance
WORKER_MIN_WORKER_USDC=5
# Minimum gas limit for USDC operations
WORKER_MIN_GAS_LIMIT_USDC=100000
# USDC contract address (should match paymaster config)
WORKER_PAYMASTER_CONTRACT_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
# Treasury private key - SECURE THIS!
WORKER_TREASURY_PRIVATE_KEY=0x2be024d79c69a2357392cb56ec2fa4b2dc3bd518d0d4466ead2a152635911ea9
# Entrypoint address (should match other configs)
WORKER_PAYMASTER_CONTRACT_ENTRYPOINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
# Uniswap V3 router address for the network
WORKER_UNISWAP_V3_ROUTER=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45
# Wrapped native token address (WETH on Ethereum, WMATIC on Polygon)
WORKER_WRAPPED_NATIVE_TOKEN=0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270
# Uniswap pool fee (3000 = 0.3%)
WORKER_UNISWAP_POOL_FEE=3000
# Pricing archive swap threshold
SHARED_PRICING_ARCHIVE_SWAP_THRESHOLD=1000000
