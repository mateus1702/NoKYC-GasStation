# =============================================================================
# Project4 AA Stack - Environment Configuration
# =============================================================================
# Copy this file and fill all values. NEVER commit .env to version control.
# Usage: docker compose -f infra/docker/docker-compose.yml --env-file .env up -d
# =============================================================================

# -----------------------------------------------------------------------------
# INFRASTRUCTURE - Anvil Local Blockchain
# -----------------------------------------------------------------------------
# Fork mode: RPC URL for Polygon mainnet (enables Anvil to fork). Leave empty for local chain.
ANVIL_FORK_URL=https://rpc.ankr.com/polygon/8ffa854920faddd72150c936d7563e370d556d26045476cb1366c69453035378
# Optional: pin to a specific block for deterministic fork (e.g. 83635022)
ANVIL_FORK_BLOCK_NUMBER=83635022

# Number of pre-funded test accounts to create (only used when not forking)
ANVIL_ACCOUNTS=5
# Seconds between blocks (1 = mine on demand, higher = timed intervals)
ANVIL_BLOCK_TIME=1
# Bind address for Anvil RPC (0.0.0.0 = all interfaces)
ANVIL_HOST=0.0.0.0
# Port for Anvil RPC
ANVIL_PORT=8545
# Chain ID to emulate (137 = Polygon mainnet)
ANVIL_CHAIN_ID=137
# Mnemonic for deterministic test accounts (Anvil defaults)
ANVIL_MNEMONIC=test test test test test test test test test test test junk
# Directory for persistent Anvil state (used when not forking)
ANVIL_STATE_DIR=/app/state

# Same as RPC_URL but specifically for contract-deployer (can point to Anvil in Docker)
ANVIL_RPC=http://anvil:8545

# -----------------------------------------------------------------------------
# WORKER SERVICE - Bootstrap & Operational Accounts
# -----------------------------------------------------------------------------
# Production/Testnet: Fund these addresses manually with required balances
# Local Development: Leave empty, worker will auto-fund from whale
#
# Bootstrap account private key (fund with 100 USDC + 0.01 ETH gas for initial setup) - Address: 0xFE3B557E8Fb62b89F4916B721be55cEb828dBd73 from Private Key: 0x8f2a55949038a9610f50fb23b5883af3b4ecb3c3bb792cbcefbd1542c692be63 
WORKER_BOOTSTRAP_PRIVATE_KEY=0xfe6640ac1926d6259c388e3e9270191b140bc2e36cecd76b1037631329a6cb55
# Revenue collection private key (to sign transfers from revenue to worker)
WORKER_REVENUE_PRIVATE_KEY=0x50329ae7d2622820ee7b1c0dd435408f2b77dc0d8d672daae718c71d5fd893c3
# Revenue collection address (where paymaster sends sponsored UserOp fees)
WORKER_REVENUE_ADDRESS=0x239504f6Ad87e4580F17bfd587602858636415e2
# Bundler service addresses (auto-derived from ALTO_UTILITY_PRIVATE_KEY and ALTO_EXECUTOR_PRIVATE_KEYS)
# WORKER_BUNDLER_ADDRESSES is automatically derived from bundler private keys
# Monitoring interval in seconds (how often worker checks balances)
WORKER_MONITORING_INTERVAL_SECONDS=10
# Minimum bootstrap USDC balance (100 USDC = 100000000 USDC units)
WORKER_MIN_BOOTSTRAP_USDC=100000000
# Minimum bootstrap gas balance (0.01 ETH = 10000000000000000 wei)
WORKER_MIN_BOOTSTRAP_GAS=10000000000000000
# Minimum worker USDC balance (50 USDC = 50000000 USDC units)
WORKER_MIN_WORKER_USDC=50000000
# Target minimum gas value for operational accounts in USDC (6 decimals)
WORKER_MIN_GAS_LIMIT_USDC=5000000
# Worker-specific RPC URL (allows load balancing across multiple providers)
WORKER_RPC_URL=http://anvil:8545
# Worker-specific USDC contract address
WORKER_PAYMASTER_CONTRACT_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
# Worker-specific treasury private key (for operational account)
WORKER_TREASURY_PRIVATE_KEY=0x97cc80e5ec35facb77093fbaab132d2a75849a6ca5e97622fb57776674f6fe00
# Worker-specific EntryPoint contract address
WORKER_PAYMASTER_CONTRACT_ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
# Worker-specific Uniswap V3 router address
WORKER_UNISWAP_V3_ROUTER=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45
# Worker-specific wrapped native token address (WMATIC on Polygon)
WORKER_WRAPPED_NATIVE_TOKEN=0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270
# Worker-specific Uniswap pool fee tier
WORKER_UNISWAP_POOL_FEE=500

# -----------------------------------------------------------------------------
# PAYMASTER CONTRACT - Configuration for ERC-4337 Paymaster Deployment
# -----------------------------------------------------------------------------
# USDC token contract address (used by paymaster for fee collection)
PAYMASTER_CONTRACT_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
# Treasury address where USDC fees are collected (must match WORKER_REVENUE_ADDRESS)
PAYMASTER_CONTRACT_TREASURY_ADDRESS=0x239504f6Ad87e4580F17bfd587602858636415e2
# ERC-4337 EntryPoint v0.7 contract address
PAYMASTER_CONTRACT_ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
# Paymaster signer address (public address corresponding to PAYMASTER_CONTRACT_SIGNER_PRIVATE_KEY)
PAYMASTER_CONTRACT_SIGNER_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
# Private key for signing paymaster operations
PAYMASTER_CONTRACT_SIGNER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
# Gas limit for paymaster signature verification
PAYMASTER_CONTRACT_VERIFICATION_GAS_LIMIT=200000
# Gas limit for paymaster post-operation processing
PAYMASTER_CONTRACT_POSTOP_GAS_LIMIT=120000

# -----------------------------------------------------------------------------
# BUNDLER (Alto) - ERC-4337 UserOp Bundling Service
# -----------------------------------------------------------------------------
# Bundler Alto RPC URL (allows load balancing across multiple providers)
ALTO_RPC_URL=http://anvil:8545
# Network name for Alto logging (e.g. polygon, local)
ALTO_NETWORK_NAME=polygon
# Log environment (production, development)
ALTO_LOG_ENV=production
# Log level (info, debug, error)
ALTO_LOG_LEVEL=info
# Minimum balance (wei) before Alto stops submitting (0 = disabled)
ALTO_MIN_BALANCE=0
# Shared max block span for eth_getLogs style queries (keeps Alto + Dashboard aligned)
ALTO_BLOCK_RANGE_LIMIT=1024
# Whether Alto should deploy simulation contracts on startup (true/false)
ALTO_DEPLOY_SIMULATIONS=false
# Private key for Alto utility account (submits userops, receives gas refunds)
ALTO_UTILITY_PRIVATE_KEY=0x73c2c03b13bb63d847ca05afa8984ef91fa884d09fa3dd47f4087c2256f20462
# Comma-separated private keys for executor accounts (submit batches, receive gas)
ALTO_EXECUTOR_PRIVATE_KEYS=0xc36a6947bcccfbe7e950e561c43e6a2cf98571668739040dd13612531084fa9c,0x5e56ac2761a0022e1a3b67c2ecfb9a3d0593fb7705f8186083c09c763ba74eaa,0x696cad356a59767cb63f8f6f5ae49f93c9097cf3656f2b90232e0d3e3192b137

# -----------------------------------------------------------------------------
# CONTRACT DEPLOYER - Smart Contract Deployment Service
# -----------------------------------------------------------------------------
# If true, contract-deployer skips mock account deployments, only runs Project4Paymaster
CONTRACT_DEPLOYER_SKIP_DEPLOYMENTS=true
# If true, deploy Project4Paymaster during contract-deployer run
CONTRACT_DEPLOYER_DEPLOY_PROJECT4_PAYMASTER=true
# Path where deployed paymaster address is written (Docker: /deploy-output/paymaster-address)
CONTRACT_DEPLOYER_PAYMASTER_ADDRESS_FILE=/deploy-output/paymaster-address
# Override path to contracts/artifacts (default: auto-resolved relative to contract-deployer)
CONTRACT_DEPLOYER_CONTRACTS_ARTIFACTS_PATH=/app/contracts-artifacts
# Private key for Hardhat deploy scripts (amoy/polygon). Leave empty for local/Docker (uses mnemonic)
CONTRACT_DEPLOYER_PRIVATE_KEY=


# -----------------------------------------------------------------------------
# PAYMASTER API
# -----------------------------------------------------------------------------
# HTTP port for paymaster API server
PAYMASTER_API_PORT=3000
# Paymaster API RPC URL (allows load balancing across multiple providers)
PAYMASTER_API_RPC_URL=http://anvil:8545
# Alto bundler URL (Docker: http://bundler-alto:4337)
PAYMASTER_API_BUNDLER_URL=http://bundler-alto:4337
# Paymaster signer moved to PAYMASTER_CONTRACT_SIGNER_PRIVATE_KEY
# Extra buffer (bps) added to quoted USDC cost to avoid underpricing (500 = 5%)
PAYMASTER_API_QUOTE_BUFFER_BPS=500
# Seconds until paymaster signature expires (user must submit before)
PAYMASTER_API_VALIDITY_SECONDS=300
# Paymaster gas limits moved to PAYMASTER_CONTRACT_* section
# Max USDC cost in stub quotes (0 = use real pricing)
PAYMASTER_API_STUB_MAX_COST_USDC_E6=0
# ERC-4337 EntryPoint address used by paymaster
PAYMASTER_API_ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
# Service fee in basis points (500 = 5%) added to gas cost quotes
PAYMASTER_API_SERVICE_FEE_BPS=500
# Paymaster API RPC URL (allows load balancing across multiple providers)
PAYMASTER_API_RPC_URL=http://anvil:8545

# -----------------------------------------------------------------------------
# DASHBOARD
# -----------------------------------------------------------------------------
# Dashboard RPC URL (allows load balancing across multiple providers)
DASHBOARD_RPC_URL=http://anvil:8545
# Paymaster API URL for dashboard health check (Docker: http://paymaster-api:3000)
PAYMASTER_API_URL=http://paymaster-api:3000
# Max block range for eth_getLogs (UserOps fetch). Docker passes BLOCK_RANGE_LIMIT; set here for local dev.
DASHBOARD_USEROPS_BLOCK_RANGE=1024
# Path to docker-compose.yml for logs panel (when running dashboard locally)
DASHBOARD_COMPOSE_FILE=infra/docker/docker-compose.yml
# Working directory for compose commands in logs panel (default: project4 root)
DASHBOARD_COMPOSE_CWD=
# ERC-4337 EntryPoint address for dashboard metrics
DASHBOARD_ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
# Treasury address for dashboard metrics
DASHBOARD_TREASURY_ADDRESS=0x239504f6Ad87e4580F17bfd587602858636415e2
# Bundler URL for dashboard health checks
DASHBOARD_BUNDLER_URL=http://bundler-alto:4337
# USDC contract address for dashboard metrics
DASHBOARD_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
# Alto utility account private key for dashboard metrics
DASHBOARD_ALTO_UTILITY_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Comma-separated Alto executor private keys for dashboard metrics
DASHBOARD_ALTO_EXECUTOR_KEYS=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80,0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d,0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
# Min EntryPoint deposit before worker tops up (wei)
DASHBOARD_MIN_ENTRYPOINT_DEPOSIT_WEI=200000000000000000
# Max EntryPoint deposit worker will maintain (wei)
DASHBOARD_CAP_ENTRYPOINT_BALANCE_WEI=1000000000000000000
# Min treasury native balance before worker tops up (wei)
DASHBOARD_MIN_WORKER_DEPOSIT_WEI=100000000000000000
# Max treasury native balance worker will maintain (wei)
DASHBOARD_CAP_WORKER_BALANCE_WEI=500000000000000000
# USDC amount (e6) to swap per refill when topping up native gas
DASHBOARD_WORKER_SWAP_USDC_E6=10000000
# Interval (ms) between worker poll cycles for dashboard metrics
DASHBOARD_POLL_INTERVAL_MS=15000


# -----------------------------------------------------------------------------
# INFRASTRUCTURE - Redis & External Services
# -----------------------------------------------------------------------------

# Redis/Valkey connection URL for pricing state and inventory
VALKEY_URL=redis://valkey:6379
# Key prefix for Redis keys (avoids collision with other projects)
VALKEY_KEY_PREFIX=project4:



# -----------------------------------------------------------------------------
# TOOLS - aa-test scripts (run with dotenv or export)
# -----------------------------------------------------------------------------
# Paymaster API URL for aa-test (local: http://127.0.0.1:3000)
TOOLS_PAYMASTER_URL=http://127.0.0.1:3000
# Private key for test account (sponsors userops, funds test accounts)
TOOLS_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# USDC amount (6 decimals) to fund test accounts
TOOLS_USDC_FUND_AMOUNT=1000
# If true, test:project4:fee keeps sending UserOps until USDC balance is empty
TOOLS_RUN_UNTIL_EMPTY=false
# Min USDC balance (e6) to continue loop when TOOLS_RUN_UNTIL_EMPTY=true (100000 = 0.1 USDC)
TOOLS_MIN_USDC_TO_CONTINUE=100000
